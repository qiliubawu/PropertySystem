@model PropertySystem.Models.Owner
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>业主电子通行证</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <style>
        body {
            background: #11998e;
            background: bg-white(to bottom, #11998e, #38ef7d);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: sans-serif;
        }

        .pass-card {
            background: white;
            width: 90%;
            max-width: 400px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
            text-align: center;
            position: relative;
        }

        .pass-header {
            background: #00b894;
            color: white;
            padding: 20px 0;
            font-size: 1.2rem;
            font-weight: bold;
            letter-spacing: 2px;
        }

        .dynamic-time {
            font-size: 2.5rem;
            font-weight: bold;
            color: #2d3436;
            margin: 15px 0;
            font-family: monospace;
        }

        .wave-circle {
            width: 100px;
            height: 100px;
            background: #55efc4;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(85, 239, 196, 0.7);
            }

            70% {
                box-shadow: 0 0 0 20px rgba(85, 239, 196, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(85, 239, 196, 0);
            }
        }
    </style>
</head>
<body>
    <div class="pass-card">
        <div class="pass-header">智慧社区·业主专属</div>

        <div class="p-4">
            <div class="wave-circle mb-3"><i class="bi bi-check-lg text-white" style="font-size: 4rem;"></i></div>

            <h4 class="fw-bold mb-1">@Model.Name</h4>
            <span class="badge bg-success mb-3 fs-6 rounded-pill px-3 py-2">业主身份核验通过</span>

            <!-- 防伪动态时间 -->
            <div class="dynamic-time" id="clock">00:00:00</div>

            <hr class="text-muted" />
            <div class="d-flex justify-content-between text-muted small text-start">
                <div><span>绑定房产：</span><br /><strong class="text-dark">@(string.IsNullOrEmpty(Model.RoomNo) ? "未绑定" : Model.RoomNo)</strong></div>
                <div class="text-end"><span>登记车牌：</span><br /><strong class="text-dark">@(string.IsNullOrEmpty(Model.CarPlate) ? "无" : Model.CarPlate)</strong></div>
            </div>
        </div>

        <div class="bg-light p-3 text-muted small">
            出示此页面即可快速通行<br />
            <a href="/Owner/Index" class="btn btn-outline-success btn-sm mt-2 rounded-pill px-4">进入业主服务大厅</a>
        </div>
    </div>

    <script>
        // 动态时钟，防止截图伪造
        setInterval(() => {
            let d = new Date();
            document.getElementById('clock').innerText =
                String(d.getHours()).padStart(2, '0') + ":" +
                String(d.getMinutes()).padStart(2, '0') + ":" +
                String(d.getSeconds()).padStart(2, '0');
        }, 1000);
    </script>
</body>
</html>

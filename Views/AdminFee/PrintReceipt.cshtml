@model PropertySystem.Models.Bill
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>收据凭证 - @Model.Owner.Name</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f0f0f0;
            display: flex;
            justify-content: center;
            padding: 40px;
            font-family: 'SimSun', '宋体', serif;
        }

        .receipt-box {
            background: white;
            width: 800px;
            padding: 50px;
            border: 1px solid #ccc;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            position: relative;
        }

        .title {
            text-align: center;
            font-size: 32px;
            font-weight: bold;
            letter-spacing: 5px;
            margin-bottom: 30px;
            border-bottom: 2px solid #000;
            padding-bottom: 20px;
        }

        .seal {
            position: absolute;
            right: 80px;
            bottom: 80px;
            width: 120px;
            height: 120px;
            border: 4px solid red;
            border-radius: 50%;
            color: red;
            text-align: center;
            line-height: 110px;
            font-size: 20px;
            font-weight: bold;
            font-family: 'KaiTi', '楷体';
            transform: rotate(-15deg);
            opacity: 0.8;
        }

        /* 打印模式：隐藏背景和按钮，只打印白纸黑字 */
        @@media print {
            body {
                background: white;
                padding: 0;
            }

            .receipt-box {
                border: none;
                box-shadow: none;
                width: 100%;
            }

            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-box">
        <div class="no-print text-center mb-4">
            <button class="btn btn-primary btn-lg px-5" onclick="window.print()"><i class="bi bi-printer"></i>点击开始打印本收据</button>
            <p class="text-muted mt-2">推荐使用 A4 纸或 A5 纸打印</p>
        </div>

        <div class="title">智慧物业管理服务专用收据</div>

        <div class="d-flex justify-content-between mb-4 fs-5">
            <div><strong>交款人 (业主)：</strong> @Model.Owner.Name </div>
            <div><strong>开票日期：</strong> @DateTime.Now.ToString("yyyy年MM月dd日") </div>
            <div><strong>凭证单号：</strong> NO.@Model.Id.ToString("D8") </div>
        </div>

        <table class="table table-bordered border-dark text-center fs-5 align-middle" style="border-width: 2px;">
            <tr class="fw-bold" style="background-color:#eee !important; -webkit-print-color-adjust: exact;">
                <td width="20%">缴费账期</td>
                <td width="20%">收费项目</td>
                <td width="40%">计费明细摘要</td>
                <td width="20%">金额 (人民币)</td>
            </tr>
            <tr style="height: 100px;">
                <td>@Model.BillingMonth</td>
                <td>@Model.FeeType</td>
                <td class="text-start px-4">@Model.Remark</td>
                <td class="fw-bold fs-4">¥ @Model.Amount.ToString("N2")</td>
            </tr>
            <tr>
                <td colspan="4" class="text-start px-4 fs-5 py-3">
                    <strong>人民币大写：</strong>
                    <span id="chineseAmount" class="fw-bold text-decoration-underline" style="margin-left: 20px;"></span>
                </td>
            </tr>
        </table>

        <div class="d-flex justify-content-between mt-5 fs-5">
            <div><strong>收款单位：</strong> 智慧物业服务有限公司 </div>
            <div><strong>收款人 (经办)：</strong> 系统自动销账 </div>
        </div>

        <!-- 模拟公章 -->
        <div class="seal">物业财务专用章</div>
    </div>

    <script>
        // 极简数字转中文大写算法
        function digitUppercase(n) {
            var fraction = ['角', '分']; var digit = ['零', '壹', '贰', '叁', '肆', '伍', '陆', '柒', '捌', '玖'];
            var unit = [['元', '万', '亿'], ['', '拾', '佰', '仟']];
            var head = n < 0 ? '欠' : ''; n = Math.abs(n); var s = '';
            for (var i = 0; i < fraction.length; i++) { s += (digit[Math.floor(n * 10 * Math.pow(10, i)) % 10] + fraction[i]).replace(/零./, ''); }
            s = s || '整'; n = Math.floor(n);
            for (var i = 0; i < unit[0].length && n > 0; i++) {
                var p = '';
                for (var j = 0; j < unit[1].length && n > 0; j++) { p = digit[n % 10] + unit[1][j] + p; n = Math.floor(n / 10); }
                s = p.replace(/(零.)*零$/, '').replace(/^$/, '零') + unit[0][i] + s;
            }
            return head + s.replace(/(零.)*零元/, '元').replace(/(零.)+/g, '零').replace(/^整$/, '零元整');
        }
        document.getElementById('chineseAmount').innerText = digitUppercase(@Model.Amount);
    </script>
</body>
</html>

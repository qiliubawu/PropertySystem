@model IEnumerable<PropertySystem.Models.SystemConfig>
@{
    ViewData["Title"] = "收费规则引擎";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <h4 class="fw-bold text-dark"><i class="bi bi-gear text-primary"></i> 动态收费规则配置</h4>
        <span class="text-muted small">系统全局变量，修改后立即在下次出账时生效</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["Success"]</div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-header bg-white fw-bold text-dark border-bottom">
                        @item.ConfigDesc
                    </div>
                    <div class="card-body bg-light">
                        <form method="post" action="/AdminFee/UpdateConfig">
                            <input type="hidden" name="id" value="@item.Id" />
                            <div class="input-group mb-3">
                                <input type="text" name="configValue" class="form-control form-control-lg text-primary fw-bold text-center border-primary" value="@item.ConfigValue" required />
                                <span class="input-group-text bg-white">基数</span>
                            </div>
                            
                            <button type="submit" class="btn btn-primary w-100 fw-bold">保存并生效新费率</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

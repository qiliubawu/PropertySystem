@model PropertySystem.Models.RepairRequest
@{
    Layout = "~/Views/Shared/_OwnerLayout.cshtml";
    ViewData["Title"] = "工单详情";
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a href="/Owner/Services" class="btn btn-sm btn-light border"><i class="bi bi-chevron-left"></i> 返回</a>
    <span class="badge bg-@(Model.Status == "待接单" ? "danger" : Model.Status == "维修中" ? "warning text-dark" : Model.Status == "待确认" ? "info text-dark" : "success")">当前状态: @Model.Status</span>
</div>

<div class="card shadow-sm border-0 mb-4" style="border-radius:15px;">
    <div class="card-body">
        <h5 class="fw-bold text-primary mb-2">@Model.RepairType</h5>
        <p class="text-muted mb-3">@Model.Description</p>
        @if (!string.IsNullOrEmpty(Model.BeforeImage))
        {
            <img src="@Model.BeforeImage" class="img-fluid rounded mb-2" style="max-height: 150px; object-fit: cover;" />
        }
    </div>
</div>

<h6 class="fw-bold text-secondary mb-3 ps-1">📍 工单处理进度</h6>
<!-- 手机端紧凑版时间轴 -->
<div class="bg-white p-3 rounded shadow-sm timeline-mobile">

    <div class="timeline-item">
        <div class="icon bg-primary"><i class="bi bi-file-earmark-plus"></i></div>
        <div class="content">
            <h6 class="fw-bold mb-1">您发起了报修</h6>
            <small class="text-muted">@Model.CreateTime.ToString("yyyy-MM-dd HH:mm")</small>
        </div>
    </div>

    <div class="timeline-item @(Model.AcceptTime == null ? "opacity-25" : "")">
        <div class="icon @(Model.AcceptTime != null ? "bg-warning" : "bg-secondary")"><i class="bi bi-person-workspace text-dark"></i></div>
        <div class="content">
            <h6 class="fw-bold mb-1">物业已接单处理</h6>
            @if (Model.AcceptTime != null)
            {
                <small class="text-muted d-block">@Model.AcceptTime?.ToString("yyyy-MM-dd HH:mm")</small>
                <span class="badge bg-light text-dark border mt-1">师傅: @(Model.Worker?.FullName ?? "调度中")</span>
            }
            else
            {

                <small class="text-muted">等待物业响应...</small>
            }
        </div>
    </div>

    <div class="timeline-item @(Model.FinishTime == null ? "opacity-25" : "")">
        <div class="icon @(Model.FinishTime != null ? "bg-info" : "bg-secondary")"><i class="bi bi-wrench"></i></div>
        <div class="content">
            <h6 class="fw-bold mb-1">维修处理完成</h6>
            @if (Model.FinishTime != null)
            {
                <small class="text-muted d-block mb-1">@Model.FinishTime?.ToString("yyyy-MM-dd HH:mm")</small>
                <div class="bg-light p-2 rounded small text-dark">留言：@Model.RepairNotes</div>
                @if (!string.IsNullOrEmpty(Model.AfterImage))
                {
                    <img src="@Model.AfterImage" class="img-fluid rounded mt-2" style="max-height: 100px;" />
                }
            }
            else
            {
                <small class="text-muted">等待师傅上门维修...</small>
            }
        </div>
    </div>

    <div class="timeline-item border-0 @(Model.ConfirmTime == null ? "opacity-25" : "")">
        <div class="icon @(Model.ConfirmTime != null ? "bg-success" : "bg-secondary")"><i class="bi bi-check-lg"></i></div>
        <div class="content">
            <h6 class="fw-bold mb-1">已评价确认</h6>
            @if (Model.ConfirmTime != null)
            {
                <small class="text-muted d-block mb-1">@Model.ConfirmTime?.ToString("yyyy-MM-dd HH:mm")</small>
                <span class="text-warning">@Html.Raw(new String('⭐', Model.Rating ?? 0))</span>
            }
            else
            {

                <small class="text-muted">等待您的验收评价</small>
            }
        </div>
    </div>
</div>

<style>
    .timeline-mobile {
        position: relative;
        padding-left: 20px;
    }

    .timeline-item {
        position: relative;
        padding-bottom: 25px;
        border-left: 2px solid #dee2e6;
        padding-left: 25px;
    }

        .timeline-item.border-0 {
            border-left: 2px solid transparent;
            padding-bottom: 0;
        }

        .timeline-item .icon {
            position: absolute;
            left: -14px;
            top: 0;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            z-index: 2;
            box-shadow: 0 0 0 4px #fff;
        }
</style>

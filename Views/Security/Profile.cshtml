@model PropertySystem.Models.User
@{
    Layout = "~/Views/Shared/_SecurityLayout.cshtml"; ViewData["Title"] = "警号档案"; ViewData["ActiveTab"] = "My";
}

@if (TempData["SharedMsg"] != null)
{
    <div class="alert alert-success text-center small py-2 mt-2">@TempData["SharedMsg"]</div>
}

<div class="text-center bg-white p-4 rounded-3 shadow-sm mt-3 border border-light mb-3">
    <i class="bi bi-shield-lock-fill text-dark" style="font-size: 5rem;"></i>
    <h3 class="fw-bold mt-2 text-dark">@Model.FullName</h3>
    <span class="badge bg-primary px-3 py-1 mt-1 rounded-pill">安保人员</span>
</div>

<button class="btn btn-outline-primary w-100 fw-bold bg-white py-3 shadow-sm mb-4" data-bs-toggle="modal" data-bs-target="#materialRequestModal">
    <i class="bi bi-box-seam me-1"></i> 提交工作物资申请
</button>

<a href="/Account/Logout" class="btn btn-danger w-100 py-3 fw-bold rounded-pill shadow-sm">下岗退出系统</a>

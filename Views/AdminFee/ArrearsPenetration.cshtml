@{
    ViewData["Title"] = "欠费穿透与催缴";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <h4 class="fw-bold text-dark"><i class="bi bi-funnel text-danger"></i> 欠费穿透追溯与催收</h4>
        <span class="badge bg-danger fs-6">欠费追缴名单</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["Success"]</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover text-center align-middle bg-white mb-0">
                <thead class="table-light">
                    <tr><th>欠费主体 (业主)</th><th>关联资产</th><th>累计欠费总额</th><th>欠费单数</th><th>账期摘要</th><th>催收动作</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.PenetrationData)
                    {
                        <tr>
                            <td class="text-start ps-4">
                                <strong class="fs-5 text-primary">@item.Owner.Name</strong><br />
                                <span class="text-muted small">电话: @item.Owner.Phone</span>
                            </td>

                            <td><span class="badge bg-light text-dark border">房: @(string.IsNullOrEmpty(item.Owner.RoomNo) ? "无" : item.Owner.RoomNo)</span></td>
                            <td class="text-danger fw-bold fs-5">¥ @item.TotalArrears.ToString("N2")</td>
                            <td><span class="badge bg-warning text-dark fs-6">@item.BillCount 笔</span></td>
                            <td class="text-muted small text-start" style="max-width: 200px;">@item.Detail</td>
                            <td>
                                <form method="post" action="/AdminFee/SendDunning">
                                    <input type="hidden" name="ownerId" value="@item.Owner.Id" />
                                    <input type="hidden" name="amount" value="@item.TotalArrears" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm fw-bold" onclick="return confirm('确定向该业主手机发送实时催费弹窗吗？');">
                                        <i class="bi bi-bell-fill"></i> 靶向实时催缴
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (((IEnumerable<dynamic>)ViewBag.PenetrationData).Count() == 0)
                    {
                        <tr><td colspan="6" class="p-5 text-muted fw-bold">太棒了！当前小区账目结清，无任何欠费业主！</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

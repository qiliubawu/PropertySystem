<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* 移动端绝对极简规范 */
        body {
            background-color: #f4f5f7;
            font-family: -apple-system, sans-serif;
            padding-bottom: 50px;
            color: #303133;
        }

        /* 抹除所有圆角、阴影、图标、渐变 */
        * {
            box-shadow: none !important;
            border-radius: 0 !important;
        }

        i[class^="bi"], svg {
            display: none !important;
        }

        [style*="linear-gradient"] {
            background: #ffffff !important;
            border: 1px solid #dfe1e6 !important;
            color: #303133 !important;
        }

        .card {
            border: 1px solid #dfe1e6 !important;
            background: #fff !important;
            margin-bottom: 12px;
        }

        .form-control, .form-select {
            border: 1px solid #dfe1e6;
            background-color: #fafbfc;
            font-size: 14px;
        }

            .form-control:focus {
                border-color: #0f52ba;
                background-color: #fff;
            }

        /* 统一的克制色彩 */
        .bg-primary, .btn-primary {
            background-color: #0f52ba !important;
            border-color: #0f52ba !important;
            color: #fff !important;
        }

        .bg-success, .btn-success {
            background-color: #238636 !important;
            border-color: #238636 !important;
            color: #fff !important;
        }

        .bg-danger, .btn-danger {
            background-color: #cb2431 !important;
            border-color: #cb2431 !important;
            color: #fff !important;
        }

        .bg-warning, .btn-warning {
            background-color: #f0f2f5 !important;
            border-color: #dfe1e6 !important;
            color: #333 !important;
        }

        .text-primary, .text-success, .text-danger, .text-warning, .text-info {
            color: #333 !important;
        }

        .badge {
            background-color: #ebecf0 !important;
            color: #42526e !important;
            border: 1px solid #dfe1e6 !important;
            font-weight: normal;
        }

        /* 顶部导航：纯白细边 */
        .top-navbar {
            background: #fff;
            color: #172b4d;
            padding: 12px;
            position: sticky;
            top: 0;
            z-index: 1000;
            text-align: center;
            font-weight: 600;
            font-size: 15px;
            border-bottom: 1px solid #dfe1e6;
        }

        /* 底部导航：纯文字矩阵 */
        .bottom-tabbar {
            position: fixed;
            bottom: 0;
            width: 100%;
            background: #fff;
            border-top: 1px solid #dfe1e6;
            display: flex;
            z-index: 1000;
            height: 50px;
        }

        .tab-item {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #7a869a;
            text-decoration: none;
            font-size: 14px;
            border-right: 1px solid #f4f5f7;
        }

            .tab-item:last-child {
                border-right: none;
            }

            .tab-item.active {
                color: #0f52ba;
                font-weight: 600;
                background-color: #f4f5f7;
                border-top: 2px solid #0f52ba;
            }

        .main-content {
            padding: 12px;
        }
    </style>
</head>
<body>
    <div class="top-navbar">@ViewData["Title"]</div>
    <div class="main-content">@RenderBody()</div>

    <!-- 纯文字无图标底部导航 -->
    <div class="bottom-tabbar">
        <a href="/Owner/Index" class="tab-item @(ViewData["ActiveTab"]?.ToString() == "Home" ? "active" : "")">首页</a>
        <a href="/Owner/Services" class="tab-item @(ViewData["ActiveTab"]?.ToString() == "Service" ? "active" : "")">服务</a>
        <a href="/Owner/Bills" class="tab-item @(ViewData["ActiveTab"]?.ToString() == "Bill" ? "active" : "")">账单</a>
        <a href="/Owner/Profile" class="tab-item @(ViewData["ActiveTab"]?.ToString() == "My" ? "active" : "")">设置</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // 移动端同样加载去除 Emoji 的全局脚本
        function removeEmojis(node) {
            if (node.nodeType === 3) {
                node.nodeValue = node.nodeValue.replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDE4F]|\uD83D[\uDE80-\uDEFF]|[\u2600-\u27BF]/g, '').trim();
            } else if (node.nodeType === 1 && node.nodeName !== 'SCRIPT' && node.nodeName !== 'STYLE') {
                for (let i = 0; i < node.childNodes.length; i++) { removeEmojis(node.childNodes[i]); }
            }
        }
        document.addEventListener("DOMContentLoaded", function() { removeEmojis(document.body); });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

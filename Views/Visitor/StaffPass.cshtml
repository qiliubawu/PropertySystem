@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>员工通行证</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <style>
        body {
            background: #2c3e50;
            background: bg-white(to right, #2c3e50, #3498db);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: sans-serif;
        }

        .pass-card {
            background: white;
            width: 90%;
            max-width: 400px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            text-align: center;
            overflow: hidden;
        }

        .pass-header {
            background: #0984e3;
            color: white;
            padding: 20px 0;
            font-size: 1.2rem;
            font-weight: bold;
            letter-spacing: 2px;
        }

        .role-text {
            color: #0984e3;
            font-weight: bold;
            border: 2px solid #0984e3;
            display: inline-block;
            padding: 5px 20px;
            border-radius: 50px;
            margin-top: 10px;
        }

        .dynamic-date {
            font-size: 1.5rem;
            font-weight: bold;
            color: #2d3436;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="pass-card">
        <div class="pass-header">内部工作人员</div>

        <div class="p-4">
            <i class="bi bi-person-badge text-primary" style="font-size: 5rem;"></i>

            <h3 class="fw-bold mt-3 mb-1">@ViewBag.StaffName</h3>
            <div class="role-text">
                @if (ViewBag.StaffRole == "Admin")
                {
                    <span>系统管理员</span>
                }
                else if (ViewBag.StaffRole == "Security")
                {

                    <span>安全保卫人员</span>
                }
                else if (ViewBag.StaffRole == "Maintenance")
                {

                    <span>维修工程师</span>
                }
                else
                {

                    <span>@ViewBag.StaffRole</span>
                }
            </div>

            <div class="dynamic-date" id="date">--</div>
            <div class="text-primary fw-bold fs-1" id="clock" style="font-family: monospace;">--</div>
        </div>

        <div class="bg-light p-3">
            <a href="/" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm">返回工作后台</a>
        </div>
    </div>

    <script>
        setInterval(() => {
            let d = new Date();
            document.getElementById('date').innerText = d.getFullYear() + "年" + (d.getMonth()+1) + "月" + d.getDate() + "日";
            document.getElementById('clock').innerText = String(d.getHours()).padStart(2, '0') + ":" + String(d.getMinutes()).padStart(2, '0') + ":" + String(d.getSeconds()).padStart(2, '0');
        }, 1000);
    </script>
</body>
</html>

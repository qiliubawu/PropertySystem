@model IEnumerable<PropertySystem.Models.CleanerTask>
@{
    Layout = "~/Views/Shared/_FireSafetyLayout.cshtml";
    ViewData["Title"] = "防火巡查日检";
    ViewData["ActiveTab"] = "Patrol";
}

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success fw-bold text-center small py-2 mb-2">@TempData["Msg"]</div>
}
@if (TempData["ErrorMsg"] != null)
{
    <div class="alert alert-danger fw-bold text-center small py-2 mb-2">@TempData["ErrorMsg"]</div>
}

<!-- 顶部提示区 (极简风) -->
<div class="bg-white p-3 rounded text-center mb-3 border">
    <h6 class="fw-bold text-dark mb-1">今日防火网格化巡查</h6>
    <p class="text-muted small mb-0" style="font-size:0.75rem;">请务必到达每个设备点位，检查压力指针及配件，并拍照留档备查。</p>
</div>

<div class="d-flex justify-content-between text-muted small mb-2 px-1 fw-bold">
    <span>全区待检总计：@Model.Count() 个</span>
    <span class="text-primary">已检：@Model.Count(t => t.Status != "待打卡") 个</span>
</div>

<!-- 任务列表 (极简线框风) -->
<div class="pb-3">
    @foreach (var item in Model)
    {
        <!-- 如果是待打卡，左侧用深蓝色细边框标识；打完卡变成浅灰色 -->
        <div class="card border mb-2 shadow-none" style="border-radius:4px; @(item.Status == "待打卡" ? "border-left: 3px solid #0f52ba !important;" : "border-left: 3px solid #dcdfe6 !important; background-color: #fafbfc;")">
            <div class="card-body py-2 px-3">
                <!-- 👇 核心修复：用标准的 C# 语法输出位置，去掉了连体文字 -->
                <h6 class="fw-bold text-dark mb-2" style="font-size:0.9rem;">点位: @item.Location</h6>

                @if (item.Status == "待打卡")
                {
                    <!-- 按钮改为低调的线框蓝 -->
                    <button class="btn btn-outline-primary btn-sm w-100 fw-bold py-1" onclick="openScanModal(@item.Id, '@item.Location')">
                        拍摄设备现状打卡
                    </button>
                }
                else
                {
                    <div class="d-flex justify-content-between text-muted" style="font-size:0.75rem;">
                        <span class="text-@(item.Status == "正常完成" ? "success" : "danger") fw-bold">@item.Status</span>
                        <span>@item.ScanTime?.ToString("HH:mm")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(item.AbnormalNotes))
                    {
                        <div class="text-danger mt-1 fw-bold" style="font-size:0.75rem;">异常: @item.AbnormalNotes</div>
                    }
                }
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="text-center text-muted p-4 small border bg-white rounded">小区内暂无消防安防设备，请通知系统管理员添加。</div>
    }
</div>

<!-- 强制拍照弹窗 (极简风) -->
<div class="modal fade" id="scanModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="align-items:flex-end; margin:0; height:100%;">
        <div class="modal-content border-0" style="border-radius:8px 8px 0 0;">
            <div class="modal-header bg-light border-bottom-0 pb-1">
                <h6 class="modal-title fw-bold text-dark mx-auto">设备查验报告</h6>
                <button type="button" class="btn-close position-absolute end-0 me-3" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/FireSafety/SubmitPatrolScan" enctype="multipart/form-data" class="modal-body bg-white pt-0">
                <input type="hidden" name="Id" id="taskId" />
                <h6 class="text-primary fw-bold text-center my-3" id="taskLoc" style="font-size:0.85rem;">--</h6>

                <div class="mb-3 p-2 bg-light border rounded">
                    <label class="form-label text-dark fw-bold small">拍摄设备仪表盘/外观 <span class="text-danger">*必须</span></label>
                    <input type="file" name="ImageFile" class="form-control form-control-sm bg-white" accept="image/*" capture="camera" required />
                </div>

                <div class="mb-4 p-2 bg-light border rounded">
                    <label class="form-label text-dark fw-bold small">异常情况记录 (如有遮挡、压力不足等)</label>
                    <textarea name="AbnormalNotes" class="form-control form-control-sm border" rows="2" placeholder="填写隐患说明..."></textarea>
                </div>

                <div class="row gx-2">
                    <div class="col-6">
                        <button type="submit" name="scanResult" value="异常" class="btn btn-outline-danger w-100 fw-bold shadow-none" onclick="return confirm('确定该设备存在安全隐患并上报？');">存在隐患</button>
                    </div>
                    <div class="col-6">
                        <button type="submit" name="scanResult" value="安全" class="btn btn-primary w-100 fw-bold shadow-none">完好正常</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>

    function openScanModal(id, loc) {
        document.getElementById('taskId').value = id;
        document.getElementById('taskLoc').innerText = loc;
        new bootstrap.Modal(document.getElementById('scanModal')).show();
    }
</script>
<style>
    .modal.fade .modal-dialog {
        transition: transform 0.3s ease-out;
        transform: translateY(100%);
    }

    .modal.show .modal-dialog {
        transform: translateY(0);
    }
</style>

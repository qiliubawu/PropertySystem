@{
    Layout = "~/Views/Shared/_OwnerLayout.cshtml";
    ViewData["Title"] = "物业服务大厅";
    ViewData["ActiveTab"] = "Service";
}

<!-- 顶部大按钮：我要报修 -->
<div class="row px-2 mb-3">
    <div class="col-6 pe-1">
        <button class="btn btn-light w-100 py-3 border fw-bold text-primary" data-bs-toggle="modal" data-bs-target="#repairModal">
            <i class="bi bi-tools fs-5 d-block mb-1"></i> 发起报修
        </button>
    </div>
    <div class="col-6 ps-1">
        <button class="btn btn-light w-100 py-3 border fw-bold text-dark" data-bs-toggle="modal" data-bs-target="#complaintModal">
            <i class="bi bi-chat-text fs-5 d-block mb-1"></i> 投诉建议
        </button>
    </div>
</div>


@if (TempData["ServiceSuccess"] != null)
{
    <div class="alert alert-success py-2 fs-6 text-center shadow-sm rounded-pill"><i class="bi bi-check-circle"></i> @TempData["ServiceSuccess"]</div>
}

<h6 class="fw-bold text-secondary mb-3 ms-1 mt-4">我的报修工单记录</h6>

<div class="pb-4">
    @foreach (var item in ViewBag.Repairs)
    {
        <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; border-left: 5px solid @(item.Status == "待接单" ? "#dc3545" : item.Status == "维修中" ? "#ffc107" : item.Status == "待确认" ? "#0dcaf0" : "#198754") !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold text-dark fs-5">@item.RepairType</span>
                    <span class="badge bg-@(item.Status == "待接单" ? "danger" : item.Status == "维修中" ? "warning text-dark" : item.Status == "待确认" ? "info text-dark" : "success")" style="font-size:0.8rem;">@item.Status</span>
                </div>
                <p class="text-muted small mb-2">@item.Description</p>
                <div class="d-flex justify-content-between text-muted small border-top pt-2">
                    <span>
                        @item.CreateTime.ToString("MM-dd")
                        <a href="/Owner/RepairDetail/@item.Id" class="ms-2 text-primary text-decoration-none">查看详情 ></a>
                    </span>

                    @if (item.Status == "待确认")
                    {
                        <!-- 如果修好了等业主确认，显示高亮评价按钮 -->
                        <button class="btn btn-sm btn-info text-dark fw-bold px-3 py-1" onclick="openEvalModal(@item.Id)">去评价验收</button>
                    }
                    else if (item.Status == "已完成")
                    {
                        <span class="text-success fw-bold">⭐ @item.Rating 星</span>
                    }
                </div>
            </div>
        </div>
    }
    @if (!((IEnumerable<dynamic>)ViewBag.Repairs).Any())
    {
        <div class="text-center text-muted p-5 mt-3"><i class="bi bi-inbox fs-1 mb-2 d-block text-secondary"></i>暂无报修记录</div>
    }
</div>
<!-- 👇 新增：我的投诉建议记录流 -->
<h6 class="fw-bold text-secondary mb-3 ms-1 mt-4">我的投诉/建议记录</h6>
<div class="pb-4">
    @foreach (var c in ViewBag.Complaints)
    {
        <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; border-left: 5px solid @(c.Status == "待处理" ? "#fd79a8" : "#00b894") !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold text-dark fs-5">@c.Title</span>
                    <span class="badge bg-@(c.Status == "待处理" ? "danger" : "success")" style="font-size:0.8rem;">@c.Status</span>
                </div>
                <p class="text-muted small mb-2">@c.Content</p>

                @if (c.Status == "已回复")
                {
                    <div class="bg-light p-3 rounded small text-dark mt-2 border border-success">
                        <strong class="text-success"><i class="bi bi-headset"></i> 物业管家回复：</strong><br />
                        @c.Reply
                    </div>
                }

                <div class="text-end text-muted small mt-2 pt-2 border-top">
                    <span>时间@c.CreateTime.ToString("MM-dd HH:mm")</span>
                </div>
            </div>
        </div>
    }
    @if (!((IEnumerable<dynamic>)ViewBag.Complaints).Any())
    {
        <div class="text-center text-muted p-4"><i class="bi bi-chat-heart fs-1 mb-2 d-block text-secondary opacity-50"></i>暂无投诉建议记录</div>
    }
</div>


<!-- 👇 新增：发起投诉弹窗 (从底部滑出) -->
<div class="modal fade" id="complaintModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="align-items: flex-end; margin:0; height:100%;">
        <div class="modal-content border-0" style="border-radius: 20px 20px 0 0; padding-bottom:env(safe-area-inset-bottom);">
            <div class="modal-header bg-light border-0">
                <h6 class="modal-title fw-bold mx-auto text-danger"><i class="bi bi-exclamation-circle-fill"></i> 客户之声 (投诉/建议)</h6>
                <button type="button" class="btn-close position-absolute end-0 me-3" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Owner/SubmitComplaint" class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold text-dark small">标题</label>
                    <input type="text" name="title" class="form-control bg-light border-0" placeholder="如：保洁态度差、电梯异响..." required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-dark small">详细说明</label>
                    <textarea name="content" class="form-control bg-light border-0" rows="5" placeholder="请详细描述发生的时间、地点和事件经过，我们将严格保护您的隐私..." required></textarea>
                </div>
                <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold rounded-pill shadow-sm">提交至物业经理信箱</button>
            </form>
        </div>
    </div>
</div>


<!-- 🛠️ 提交报修弹窗 (底部滑出) -->
<div class="modal fade" id="repairModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="align-items: flex-end; margin:0; height:100%;">
        <div class="modal-content border-0" style="border-radius: 20px 20px 0 0; padding-bottom:env(safe-area-inset-bottom);">
            <div class="modal-header bg-light border-0">
                <h6 class="modal-title fw-bold mx-auto">发起新的报修</h6>
                <button type="button" class="btn-close position-absolute end-0 me-3" data-bs-dismiss="modal"></button>
            </div>
            <!-- 必须加 enctype="multipart/form-data" 才能传图片 -->
            <form method="post" action="/Owner/SubmitRepair" enctype="multipart/form-data" class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold text-primary small">报修项目分类</label>
                    <select name="RepairType" class="form-select bg-light border-0" required>
                        <option value="水路管道">水路管道</option>
                        <option value="电路电器">电路电器</option>
                        <option value="门窗锁具">门窗锁具</option>
                        <option value="公共设施">公共设施</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-primary small">故障详细描述</label>
                    <textarea name="Description" class="form-control bg-light border-0" rows="3" placeholder="请描述具体坏了哪里..." required></textarea>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-primary small">现场拍照 (选填)</label>
                    <input type="file" name="BeforeImageFile" class="form-control bg-light border-0" accept="image/*" capture="camera" />
                    <small class="text-muted" style="font-size:0.7rem;">可直接调用手机摄像头拍照</small>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold rounded-pill shadow-sm">提交报修单</button>
            </form>
        </div>
    </div>
</div>

<!-- ⭐ 评价验收弹窗 -->
<div class="modal fade" id="evalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-center w-100">服务验收与评价</h6>
            </div>
            <form method="post" action="/Owner/EvaluateRepair" class="modal-body text-center">
                <input type="hidden" name="repairId" id="evalRepairId" />
                <p class="text-muted small mb-3">师傅已上传处理结果，请您验收打分</p>

                <div class="mb-3">
                    <select name="rating" class="form-select form-select-lg text-warning fw-bold text-center border-warning" required>
                        <option value="5">⭐⭐⭐⭐⭐ 极其满意</option>
                        <option value="4">⭐⭐⭐⭐ 比较满意</option>
                        <option value="3">⭐⭐⭐ 感觉一般</option>
                        <option value="2">⭐⭐ 服务太差</option>
                        <option value="1">⭐ 根本没修好</option>
                    </select>
                </div>
                <div class="mb-4">
                    <textarea name="evaluation" class="form-control bg-light" rows="2" placeholder="写两句夸夸师傅吧..." required></textarea>
                </div>

                <button type="submit" class="btn btn-info w-100 fw-bold text-dark rounded-pill">确认结案</button>
            </form>
        </div>
    </div>
</div>

<script>
    function openEvalModal(id) {
        document.getElementById('evalRepairId').value = id;
        new bootstrap.Modal(document.getElementById('evalModal')).show();
    }
</script>

<style>
    /* 底部弹出动画 */
    .modal.fade .modal-dialog {
        transition: transform 0.3s ease-out;
        transform: translateY(100%);
    }

    .modal.show .modal-dialog {
        transform: translateY(0);
    }
</style>

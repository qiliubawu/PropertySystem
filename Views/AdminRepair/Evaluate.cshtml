@model PropertySystem.Models.RepairRequest
@{
    ViewData["Title"] = "工单评价";
}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-info">工单确认与评价</h2><hr />
            <div class="card mb-4 border-info">
                <div class="card-body text-center">
                    <h5 class="text-muted">维修工留言：</h5>
                    <p class="fs-5">@Model.RepairNotes</p>
                    @if (Model.AfterImage != null)
                    {
                        <img src="@Model.AfterImage" class="img-fluid rounded mt-2" style="max-height:200px;" />
                    }
                </div>
            </div>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">服务星级 (1-5)</label>
                    <select name="rating" class="form-select text-warning fw-bold text-center" required>
                        <option value="5">⭐⭐⭐⭐⭐ 非常满意</option>
                        <option value="4">⭐⭐⭐⭐ 满意</option>
                        <option value="3">⭐⭐⭐ 一般</option>
                        <option value="2">⭐⭐ 不满意</option>
                        <option value="1">⭐ 极差</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">评价文字</label>
                    <textarea name="evaluation" class="form-control" rows="2" placeholder="写点评价吧..." required></textarea>
                </div>
                <button type="submit" class="btn btn-info w-100 text-dark fw-bold">确认完成工单</button>
            </form>
        </div>
    </div>
</div>

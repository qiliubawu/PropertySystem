@model PropertySystem.Models.PaginatedList<PropertySystem.Models.Equipment>

@{
    ViewData["Title"] = "设备台账大屏";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>智能设备物联与维保中心</h2>
        <        <div>
            <!-- 👇 这里的链接指向 BlueprintDeploy -->
            <a href="/AdminEquipment/BlueprintDeploy" class="btn btn-warning fw-bold text-dark me-2 shadow-sm"><i class="bi bi-diagram-3"></i> 一键蓝图部署</a>
            <a href="/AdminEquipment/Create" class="btn btn-success fw-bold shadow-sm">单条录入</a>
            <form method="post" action="/AdminEquipment/ClearAll" class="d-inline" onsubmit="return confirm('危险！将清空所有设备！确定吗？')">
                <button type="submit" class="btn btn-outline-danger ms-2 fw-bold shadow-sm">一键清空</button>
            </form>
        </div>


    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold">@TempData["Success"]</div>
    }

    <!-- 📊 维保状态看板 -->
    <!-- 📊 B端标准设备看板 -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 border-start border-primary border-3 shadow-sm">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">设备总资产数</div>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.TotalCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-success border-3 shadow-sm">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">健康运行中</div>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.NormalCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-warning border-3 shadow-sm">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">维保临期预警</div>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.UrgentCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-danger border-3 shadow-sm">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">故障停机报修</div>
                    <h3 class="fw-bold text-dark mb-0">@ViewBag.ErrorCount</h3>
                </div>
            </div>
        </div>
    </div>


    <!-- 筛选区 -->
    <form method="get" class="row g-3 mb-4 bg-light p-3 border rounded shadow-sm">
        <div class="col-auto"><input type="text" name="searchName" class="form-control" placeholder="搜编号/名称" value="@ViewBag.SearchName" /></div>
        <div class="col-auto">
            <select name="searchCategory" class="form-select">
                <option value="">-- 所有类别 --</option>
                <option value="特种设备">特种设备(电梯等)</option>
                <option value="消防安防">消防安防</option>
                <option value="水电气暖">水电气暖</option>
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">过滤设备</button>
            <a href="/AdminEquipment/Index" class="btn btn-light border text-muted">重置</a>
        </div>

    </form>

    <table class="table table-bordered table-hover text-center align-middle bg-white shadow-sm">
        <thead class="table-dark">
            <tr>
                <th width="8%">预警状态</th>
                <th width="20%">设备编号/名称</th>
                <th width="15%">安装位置</th>
                <th width="10%">运行状态</th>
                <th width="15%">下次维保期限</th>
                <th width="32%">系统操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsMaintenanceUrgent ? "table-danger" : "")">
                    <td>
                        @if (item.IsMaintenanceUrgent)
                        {
                            <span class="badge bg-danger fs-6 ">预警</span>
                        }
                        else
                        {

                            <span class="text-success fs-5"><i class="bi bi-shield-check"></i> ✅</span>
                        }
                    </td>
                    <td class="text-start">
                        <span class="text-primary fw-bold">@item.EquipmentNo</span><br />
                        <strong class="fs-6">@item.Name</strong>
                        <span class="badge bg-light text-dark border ms-1">@item.Category</span>
                    </td>
                    <td>@item.Location</td>
                    <td><span class="badge bg-@(item.Status == "正常运行" ? "success" : item.Status == "故障报修" ? "warning text-dark" : "secondary")">@item.Status</span></td>
                    <td class="fw-bold @(item.IsMaintenanceUrgent ? "text-danger" : "text-success")">
                        @(item.NextMaintenanceDate?.ToString("yyyy-MM-dd") ?? "未设置")
                    </td>
                    <td>
                        <!-- 二维码按钮 -->
                        <button class="btn btn-sm btn-dark" onclick="showQR('@item.EquipmentNo', '@item.Name')">一物一码</button>
                        <!-- 一键续期 -->
                        <a href="/AdminEquipment/RenewMaintenance/@item.Id" class="btn btn-sm btn-success" onclick="return confirm('确认该设备今日已完成检修保养吗？(期限将自动延后1年)');">🔧 一键续期</a>

                        <a href="/AdminEquipment/Edit/@item.Id" class="btn btn-sm btn-outline-primary">✏️</a>
                        <a href="/AdminEquipment/Delete/@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('确定报废该设备吗？');">🗑</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <partial name="_Pagination" model="Model" />
</div>

<!-- 动态二维码弹窗 -->
<div class="modal fade" id="qrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-dark shadow-sm"">
            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title fw-bold">设备巡检专属二维码</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <h5 id="qrEquipName" class="text-primary fw-bold mb-3"></h5>
                <!-- 放置二维码 -->
                <div id="qrcode" class="d-flex justify-content-center p-2 bg-white border rounded"></div>
                <p class="mt-3 text-muted small">将此二维码打印贴于设备表面<br />巡检员扫码即可查看电子档案</p>
            </div>
        </div>
    </div>
</div>

<!-- 引入生成二维码的 JS 库 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    function showQR(eqNo, eqName) {
        document.getElementById("qrEquipName").innerText = eqName;
        document.getElementById("qrcode").innerHTML = "";

        // 动态生成扫码指向的网址 (PublicDetail)
        var url = window.location.protocol + "//" + window.location.host + "/AdminEquipment/PublicDetail?eqNo=" + eqNo;

        new QRCode(document.getElementById("qrcode"), {
            text: url, width: 200, height: 200, colorDark: "#000", colorLight: "#fff", correctLevel: QRCode.CorrectLevel.H
        });

        new bootstrap.Modal(document.getElementById('qrModal')).show();
    }
</script>

<style>
    .hover-card {
        transition: transform 0.2s;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }

    

    @@keyframes beat {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

@model PropertySystem.Models.Owner
@{
    ViewData["Title"] = "录入新业主";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>录入新业主档案</h2><hr />
            <form method="post" action="/AdminOwner/Create">
                <div class="mb-3"><label class="form-label text-muted small fw-bold">真实姓名</label><input asp-for="Name" class="form-control" required /></div>
                <div class="row">
                    <div class="col-6 mb-3"><label class="form-label text-muted small fw-bold">性别</label><select asp-for="Gender" class="form-select"><option value="男">男</option><option value="女">女</option></select></div>
                    <div class="col-6 mb-3"><label class="form-label text-muted small fw-bold">年龄</label><input asp-for="Age" class="form-control" type="number" required /></div>
                </div>
                <div class="mb-3"><label class="form-label text-muted small fw-bold">手机号 (将作为登录账号)</label><input asp-for="Phone" class="form-control" required /></div>
                <div class="mb-3 p-3 bg-light border border-warning rounded">
                    <label class="form-label fw-bold text-danger">设置登录密码 (默认123456)</label>
                    <input asp-for="LoginPassword" class="form-control border-danger" type="text" value="123456" placeholder="至少输入 6 位字符" required />
                    <span asp-validation-for="LoginPassword" class="text-danger"></span>
                </div>

                <div class="mb-3"><label class="form-label text-muted small fw-bold">电子邮箱 (选填)</label><input asp-for="Email" class="form-control" /></div>
                <div class="mb-4"><label class="form-label text-success fw-bold">车牌号码 (选填)</label><input asp-for="CarPlate" class="form-control border-success" placeholder="如：京A·88888" /></div>

                <button type="submit" class="btn btn-primary w-100 fw-bold mt-2 shadow-sm">保存档案</button>
                <a href="/AdminOwner/Index" class="btn btn-link w-100 mt-2 text-center text-muted text-decoration-none">返回列表</a>
            </form>
        </div>
    </div>
</div>

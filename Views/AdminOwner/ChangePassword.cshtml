@model PropertySystem.Models.Owner
@{
    ViewData["Title"] = "修改密码";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-info">
                <div class="card-header bg-info text-dark fw-bold text-center">
                    <h5>修改业主密码：@Model.Name</h5>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <p class="text-muted small mb-4">登录账号：<strong>@Model.Phone</strong></p>

                    <form method="post" action="/AdminOwner/ChangePassword/@Model.Id">
                        <div class="mb-4">
                            <label class="form-label fw-bold">请输入新密码</label>
                            <input type="text" name="newPassword" class="form-control form-control-lg border-primary"
                                   placeholder="至少输入 6 位字符 (纯数字即可)" required autocomplete="off" />
                        </div>


                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">确认修改</button>
                        <a href="/AdminOwner/Index" class="btn btn-link w-100 mt-2 text-center text-muted">取消并返回列表</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "员工 KPI 排行榜";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <h4 class="fw-bold text-dark"><i class="bi bi-bar-chart-steps text-warning"></i> 维修工程部 KPI 龙虎榜</h4>
        <span class="text-muted small">依据真实工单流转与业主盲评自动生成</span>
    </div>

    <div class="row mt-4">
        @{
            int rank = 1;
        }
        @foreach (var item in ViewBag.Rankings)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <!-- 根据排名渲染顶部横条颜色 -->
                    <div class="card-header border-0 @(rank == 1 ? "bg-warning" : rank == 2 ? "bg-secondary text-white" : rank == 3 ? "bg-danger text-white" : "bg-primary text-white") text-center py-2">
                        <h6 class="fw-bold mb-0">No.@rank</h6>
                    </div>
                    <div class="card-body text-center bg-light">
                        <div class="bg-white border rounded-circle d-inline-flex justify-content-center align-items-center fw-bold fs-2 mb-3 shadow-sm text-dark" style="width: 70px; height: 70px;">
                            @item.WorkerName.Substring(0, 1)
                        </div>
                        <h5 class="fw-bold text-dark mb-1">@item.WorkerName</h5>
                        <div class="text-warning fs-5 fw-bold mb-3">@item.AvgRating.ToString("0.0") <i class="bi bi-star-fill fs-6"></i></div>

                        <ul class="list-group list-group-flush text-start small">
                            <li class="list-group-item bg-transparent px-0 d-flex justify-content-between">
                                <span class="text-muted">总接单量</span><strong class="text-dark">@item.TotalOrders</strong>
                            </li>
                            <li class="list-group-item bg-transparent px-0 d-flex justify-content-between">
                                <span class="text-muted">结案单量</span><strong class="text-success">@item.CompletedOrders</strong>
                            </li>
                            <li class="list-group-item bg-transparent px-0 d-flex justify-content-between border-0">
                                <span class="text-muted">五星好评</span><strong class="text-danger">@item.GoodReviews</strong>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            rank++;
        }
        @if (((IEnumerable<dynamic>)ViewBag.Rankings).Count() == 0)
        {
            <div class="col-12"><p class="text-muted p-4 text-center bg-white rounded border">暂无维修工接单数据</p></div>
        }
    </div>
</div>

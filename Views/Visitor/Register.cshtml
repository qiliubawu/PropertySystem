@model PropertySystem.Models.Visitor
@{
    Layout = null; // 手机端不需要后台的导航栏
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>访客自助登记</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .register-box {
            background: white;
            border-radius: 15px;
            padding: 25px;
            margin: 20px auto;
            max-width: 500px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .header-title {
            color: #2c3e50;
            font-weight: bold;
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="register-box">
            <h3 class="header-title">访客自助登记</h3>
            <p class="text-muted text-center small mb-4">为了小区的安全，请如实填写您的身份信息</p>

            <form method="post" action="/Visitor/Register">
                <div class="mb-3">
                    <label class="form-label text-primary fw-bold">姓名</label>
                    <input asp-for="Name" class="form-control form-control-lg" placeholder="请输入真实姓名" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label text-primary fw-bold">性别</label>
                        <select asp-for="Gender" class="form-select form-control-lg">
                            <option value="男">男</option>
                            <option value="女">女</option>
                        </select>
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label text-primary fw-bold">年龄</label>
                        <input asp-for="Age" class="form-control form-control-lg" type="number" placeholder="年龄" />
                        <span asp-validation-for="Age" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-primary fw-bold">手机号</label>
                    <input asp-for="Phone" class="form-control form-control-lg" type="tel" placeholder="11位手机号码" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <!-- 👇 新增：车辆信息与起止时间 -->
                <div class="mb-3 p-3 bg-light rounded border border-success">
                    <label class="form-label text-success fw-bold"><i class="bi bi-car-front-fill"></i> 车辆号牌 (步行免填)</label>
                    <input asp-for="CarPlate" class="form-control form-control-lg border-success" placeholder="如：京A·88888" />
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label text-primary fw-bold">预计进入时间</label>
                        <!-- type="datetime-local" 会调用手机原生滚轮选时间 -->
                        <input asp-for="StartTime" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label text-danger fw-bold">预计离开时间</label>
                        <input asp-for="EndTime" class="form-control" type="datetime-local" value="@DateTime.Now.AddHours(2).ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <small class="text-muted mt-1" style="font-size:0.75rem;">提示：通行码仅在此时间段内有效，超时系统将自动注销通行权限。</small>
                </div>
                <!-- 👆 新增结束 -->

                <div class="mb-4">
                    <label class="form-label text-primary fw-bold">来访目的</label>
                    ...

                    <select asp-for="Purpose" class="form-select form-control-lg">
                        <option value="探亲访友">探亲访友</option>
                        <option value="外卖送餐">外卖送餐</option>
                        <option value="快递物流">快递物流</option>
                        <option value="房屋装修">房屋装修</option>
                        <option value="设备维修">设备维修</option>
                        <option value="其他">其他</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">提交登记并通行</button>
            </form>
        </div>
    </div>

    <!-- 引入前端验证，手机端不刷新报错 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

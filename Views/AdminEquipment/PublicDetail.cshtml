@model PropertySystem.Models.Equipment
@{
    Layout = null; /* 去掉后台导航栏，纯粹的手机 H5 页面 */
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>设备电子档案 - @Model.EquipmentNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f7f6;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
        }

        .info-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin: 20px;
            overflow: hidden;
        }

        .header-bg {
            background: bg-white(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 30px 20px;
            text-align: center;
        }

        .data-row {
            display: flex;
            justify-content: space-between;
            padding: 15px 20px;
            border-bottom: 1px solid #eee;
        }

        .data-label {
            color: #6c757d;
            font-weight: 500;
        }

        .data-value {
            font-weight: bold;
            color: #2c3e50;
            text-align: right;
        }
    </style>
</head>
<body>

    <div class="info-card">
        <!-- 头部信息 -->
        <div class="header-bg">
            <h5 class="mb-1 opacity-75">设备唯一识别码</h5>
            <h2 class="fw-bold mb-3" style="letter-spacing: 2px;">@Model.EquipmentNo</h2>
            <span class="badge rounded-pill bg-@(Model.Status == "正常运行" ? "success" : Model.Status == "故障报修" ? "warning text-dark" : "secondary") fs-6 px-3 py-2">
                当前状态：@Model.Status
            </span>
        </div>

        <!-- 详细参数 -->
        <div class="data-row">
            <span class="data-label">设备名称</span>
            <span class="data-value text-primary fs-5">@Model.Name</span>
        </div>
        <div class="data-row">
            <span class="data-label">设备分类</span>
            <span class="data-value">@Model.Category</span>
        </div>
        <div class="data-row">
            <span class="data-label">安装位置</span>
            <span class="data-value">@Model.Location</span>
        </div>
        <div class="data-row">
            <span class="data-label">维保单位</span>
            <span class="data-value">@(Model.Supplier ?? "暂无信息")</span>
        </div>

        <!-- 维保安全区 -->
        <div class="p-3 bg-light m-3 rounded border">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted small">上次维保：</span>
                <strong class="text-success">@(Model.LastMaintenanceDate?.ToString("yyyy-MM-dd") ?? "--")</strong>
            </div>
            <div class="d-flex justify-content-between">
                <span class="text-muted small">下次期限：</span>
                <strong class="@(Model.IsMaintenanceUrgent ? "text-danger " : "text-dark")">
                    @(Model.NextMaintenanceDate?.ToString("yyyy-MM-dd") ?? "未定")
                </strong>
            </div>
            @if (Model.IsMaintenanceUrgent)
            {
                <div class="alert alert-danger mt-2 mb-0 p-2 text-center small fw-bold">
                    警告：该设备维保已超期或不足30天！
                </div>
            }
        </div>
    </div>

    <p class="text-center text-muted small mt-4 pb-4">智慧社区物联引擎 提供技术支持</p>

</body>
</html>
